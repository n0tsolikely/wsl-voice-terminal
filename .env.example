# Copy this file to .env and fill in your real key.
OPENAI_API_KEY=your_key_here
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy
OPENAI_API_BASE=https://api.openai.com/v1

# Local faster-whisper fallback settings. These are used only when OPENAI_API_KEY is empty.
LOCAL_WHISPER_MODEL=base.en
LOCAL_WHISPER_DEVICE=cpu
LOCAL_WHISPER_COMPUTE_TYPE=int8
LOCAL_WHISPER_LANGUAGE=en

# Optional WSL overrides:
# WSL_EXECUTABLE=wsl.exe
# WSL_ARGS=
